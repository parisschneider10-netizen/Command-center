# Command Center + Voice OS — Sovereign Stack

# ── Core ──────────────────────────────────────────────────
SECRET_KEY=generate-a-long-random-string-here
PORTAL_USERNAME=commander
PORTAL_PASSWORD=change-me-to-something-strong
DATABASE_URL=sqlite+aiosqlite:///./data/command_center.db
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
PUBLIC_BASE_URL=https://your-vps-domain.com
VAPI_WEBHOOK_SECRET=

# ── SARA machine-wire (drop key once — system wires via API) ─
# VAPI_API_KEY=from dashboard.vapi.ai → API Keys
# VAPI_ASSISTANT_ID=optional — auto-picks first assistant
# VAPI_PHONE_NUMBER_ID=optional
# VPS_PUBLIC_IP=157.254.194.89
# PUBLIC_HTTPS_URL=https://157-254-194-89.sslip.io
# MACHINE_WIRE_TOKEN=auto-generated for GitHub Actions wire

# ── Obsidian vault (markdown memory) ─────────────────────
VAULT_PATH=./vault

# ── n8n orchestration ─────────────────────────────────────
# Base URL for webhook triggers, e.g. https://your-domain.com/webhook
N8N_WEBHOOK_BASE_URL=https://your-domain.com/webhook
N8N_HOST=your-domain.com
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://your-domain.com
N8N_ENCRYPTION_KEY=generate-another-long-random-string

# ── Postgres (used by n8n) ────────────────────────────────
POSTGRES_USER=empire
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=empire

# ── Expansion value node (STR / GHL / Servury) ────────────
# SERVURY_API_KEY=
# SERVURY_API_URL=https://api.servury.com
# GHL_API_KEY=
# GHL_COMPANY_ID=
# GHL_MTR_RECON_SNAPSHOT_ID=
EXPANSION_DRY_RUN=true
EXPANSION_MAX_CITIES=40
EXPANSION_LIVE_BATCH_CAP=5
TREASURY_HOLD_HOURS=48
TREASURY_AMMO_PERCENT=70
TREASURY_OPS_RESERVE_PERCENT=30
TREASURY_AUTO_FUND_ACQUISITIONS=true
# EMPIRE_TIER_OVERRIDE=0
# BRAVE_SEARCH_API_KEY=
# OPENAI_API_KEY=
# SKYVERN_API_KEY=

# ── Human layer (RentAHuman + guardians) ──────────────────
# RENTAHUMAN_API_KEY=
GUARDIAN_PER_TASK_CAP=25
COMMANDER_DAILY_BUDGET_CAP=100

# ── Comms layer (Gmail replacement) ───────────────────────
# COMMS_IMAP_HOST=mail.yourdomain.com
# COMMS_IMAP_PORT=993
# COMMS_IMAP_USER=commander@yourdomain.com
# COMMS_IMAP_PASSWORD=
# COMMS_SMTP_HOST=mail.yourdomain.com
# COMMS_SMTP_PORT=587
# COMMS_SMTP_USER=commander@yourdomain.com
# COMMS_SMTP_PASSWORD=
COMMS_FROM_NAME=Commander
COMMS_AUTO_SEND_ROUTINE=true

# ── Communication bridge ───────────────────────────────────
# BRIDGE_WEBHOOK_SECRET=generate-random-string
# BRIDGE_ALLOWED_SENDERS=you@gmail.com

# ── Intent engine + human firewall ─────────────────────────
KCMO_MAX_UNITS=30
TREASURY_SALES_CLOSE_HOLD_HOURS=4

# ── Timezone ──────────────────────────────────────────────
TZ=America/New_York
