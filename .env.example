# Command Center + Voice OS — Sovereign Stack

# ── Core ──────────────────────────────────────────────────
SECRET_KEY=generate-a-long-random-string-here
PORTAL_USERNAME=commander
PORTAL_PASSWORD=change-me-to-something-strong
DATABASE_URL=sqlite+aiosqlite:///./data/command_center.db
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
PUBLIC_BASE_URL=https://your-vps-domain.com
VAPI_WEBHOOK_SECRET=

# ── SARA machine-wire (drop key once — system wires via API) ─
# VAPI_API_KEY=from dashboard.vapi.ai → API Keys
# VAPI_ASSISTANT_ID=optional — auto-picks first assistant
# VAPI_PHONE_NUMBER_ID=optional
# VPS_PUBLIC_IP=157.254.194.89
# PUBLIC_HTTPS_URL=https://157-254-194-89.sslip.io
# MACHINE_WIRE_TOKEN=auto-generated for GitHub Actions wire

# ── Obsidian vault (markdown memory) ─────────────────────
# LLM_API_KEY=             # Ready Room vision (Commander name) — or OPENAI_API_KEY
# OPENAI_API_KEY=          # Same endpoint — use whichever you set
VAULT_PATH=./vault

# ── Ready Room chat + Telegram (optional mobile bridge) ───
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=random-long-string
# TELEGRAM_COMMANDER_CHAT_IDS=123456789

# ── n8n orchestration ─────────────────────────────────────
# Base URL for webhook triggers, e.g. https://your-domain.com/webhook
N8N_WEBHOOK_BASE_URL=https://your-domain.com/webhook
N8N_HOST=your-domain.com
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://your-domain.com
N8N_ENCRYPTION_KEY=generate-another-long-random-string

# ── Postgres (used by n8n) ────────────────────────────────
POSTGRES_USER=empire
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=empire

